# Strava API (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Public base URL of this app (no trailing /). Must match how you open the UI in the browser.
# Strava callback domain must allow this host; full redirect URI is:
#   {PUBLIC_BASE_URL}/api/auth/callback
# Unraid LAN example: http://192.168.1.50:8787
PUBLIC_BASE_URL=http://localhost:8787

# Optional: directory for token file (default in Docker: /data)
# DATA_DIR=/data

# Optional: max pages of 200 activities to fetch (default 50 ≈ 10k activities)
# MAX_ACTIVITY_PAGES=50
